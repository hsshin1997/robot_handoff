  <link name="base"/>
  <joint name="base_link-base" type="fixed">
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.103"/>
    <axis xyz="0 0 1"/>
    <parent link="base_link"/>
    <child link="base"/>
  </joint>
  <!-- Simple two-finger parallel gripper (fixed open, no jaw actuation).
       Gripper frame: z = tool axis (out of the flange), fingers close
       across y. TCP = center between the fingertips at z = 0.200 from the
       flange, where the part COG is grasped. gripper.STL kept in meshes/. -->
  <link name="gripper">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.08"/>
      <mass value="1.0"/>
      <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.002"/>
    </inertial>
    <visual name="palm">
      <origin rpy="0 0 0" xyz="0 0 0.050"/>
      <geometry><box size="0.090 0.095 0.100"/></geometry>
      <material name="palm_grey"><color rgba="0.55 0.55 0.58 1"/></material>
    </visual>
    <visual name="finger_left">
      <origin rpy="0 0 0" xyz="0 0.013 0.150"/>
      <geometry><box size="0.005 0.002 0.100"/></geometry>
      <material name="finger_dark"><color rgba="0.25 0.25 0.28 1"/></material>
    </visual>
    <visual name="finger_right">
      <origin rpy="0 0 0" xyz="0 -0.013 0.150"/>
      <geometry><box size="0.005 0.002 0.100"/></geometry>
      <material name="finger_dark2"><color rgba="0.25 0.25 0.28 1"/></material>
    </visual>
    <collision name="palm_col">
      <origin rpy="0 0 0" xyz="0 0 0.050"/>
      <geometry><box size="0.090 0.095 0.100"/></geometry>
    </collision>
    <collision name="finger_left_col">
      <origin rpy="0 0 0" xyz="0 0.013 0.150"/>
      <geometry><box size="0.005 0.002 0.100"/></geometry>
    </collision>
    <collision name="finger_right_col">
      <origin rpy="0 0 0" xyz="0 -0.013 0.150"/>
      <geometry><box size="0.005 0.002 0.100"/></geometry>
    </collision>
  </link>
  <joint name="tool0-gripper" type="fixed">
    <parent link="tool0"/>
    <child link="gripper"/>
    <origin rpy="0 1.57079633 0" xyz="0 0 0"/>
  </joint>
  <link name="tcp"/>
  <joint name="gripper-tcp" type="fixed">
    <parent link="gripper"/>
    <child link="tcp"/>
    <origin rpy="0 0 0" xyz="0 0 0.200"/>
  </joint>
</robot>
